{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchPackageNames": ["@tauri-apps/*", "tauri*"],
      "groupName": "Tauri packages",
      "groupSlug": "tauri"
    },
    {
      "matchPackageNames": [
        "vue",
        "vue-tsc",
        "@vitejs/plugin-vue",
        "@vue/test-utils",
        "eslint-plugin-vue",
        "eslint-plugin-vuejs-accessibility"
      ],
      "groupName": "Vue ecosystem",
      "groupSlug": "vue"
    },
    {
      "matchPackageNames": [
        "vite",
        "vitest",
        "happy-dom",
        "@tailwindcss/vite",
        "tailwindcss"
      ],
      "groupName": "Build & test tooling",
      "groupSlug": "build-tooling"
    },
    {
      "matchPackageNames": [
        "eslint",
        "prettier",
        "typescript-eslint",
        "@eslint/js",
        "eslint-config-prettier"
      ],
      "groupName": "Linting",
      "groupSlug": "linting"
    },
    {
      "matchPackageNames": ["typescript"],
      "groupName": "TypeScript",
      "groupSlug": "typescript"
    },
    {
      "matchPackageNames": ["@lucide/vue"],
      "groupName": "Icons",
      "groupSlug": "icons"
    },
    {
      "matchManagers": ["cargo"],
      "matchPackageNames": ["serde", "serde_json"],
      "groupName": "Rust serialization",
      "groupSlug": "rust-serde"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "timezone": "Asia/Shanghai",
  "schedule": ["before 9am on Monday"]
}
