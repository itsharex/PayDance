{
  "name": "pay-dance",
  "private": true,
  "version": "0.6.9",
  "author": "Mr.Baober",
  "repository": "github:MasterBao66/PayDance",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "check:brand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-brand-hygiene.ps1",
    "check:secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-secrets.ps1",
    "check:hygiene": "npm.cmd run check:brand && npm.cmd run check:secrets",
    "verify": "npm.cmd run check:hygiene && npm.cmd test && npm.cmd run build",
    "preview": "vite preview",
    "version:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-version-consistency.ps1",
    "release:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-release-unlocked.ps1",
    "prebuild:exe": "npm.cmd run release:check && npm.cmd run version:check",
    "build:exe": "tauri build --no-bundle",
    "prebuild:installer": "npm.cmd run release:check && npm.cmd run version:check",
    "build:installer": "tauri build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
