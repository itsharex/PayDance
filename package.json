{
  "name": "pay-dance",
  "private": true,
  "version": "0.8.14",
  "author": "Mr.Baoboer",
  "repository": "github:MasterBao66/PayDance",
  "type": "module",
  "scripts": {
    "dev": "vite --mode desktop",
    "dev:web": "vite --mode web",
    "build": "npm run build:desktop",
    "build:desktop": "vue-tsc --noEmit && vite build --mode desktop --configLoader runner && node scripts/assert-build-target.mjs desktop",
    "build:web": "vue-tsc --noEmit && vite build --mode web --configLoader runner && node scripts/assert-build-target.mjs web",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"scripts/**/*.mjs\" \"src-tauri/**/*.{js,json}\" \".github/workflows/*.yml\" \"*.{json,html,js,ts}\"",
    "check:brand": "node scripts/check-brand-hygiene.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:hygiene": "npm run check:brand && npm run check:secrets",
    "verify": "npm run verify:fast",
    "verify:fast": "npm run check:hygiene && npm run lint && npm run format:check && npm test && npm run build:desktop && npm run build:web",
    "verify:release": "npm run verify:fast && npm run version:check && npm run release:check && npm audit --omit=dev && cd src-tauri && cargo fmt --all -- --check && cargo check && cargo clippy --all-targets -- -D warnings",
    "qa:web-preview": "node scripts/qa-web-preview.mjs",
    "setup:encoding": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-dev-encoding.ps1",
    "preview": "vite preview",
    "version:check": "node scripts/ensure-version-consistency.mjs",
    "release:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-release-unlocked.ps1",
    "prebuild:exe": "npm run release:check && npm run version:check",
    "build:exe": "tauri build --no-bundle",
    "prebuild:installer": "npm run release:check && npm run version:check",
    "build:installer": "tauri build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
